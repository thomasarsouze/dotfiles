#!/usr/bin/env bash
set -euo pipefail

PROFILE=$(find "$HOME/Library/Application Support/Firefox/Profiles" \
  -maxdepth 1 -type d -name "*.default*" | head -n1)

DB="$PROFILE/places.sqlite"
TMP=$(mktemp)

cp "$DB" "$TMP"

sqlite3 -tabs "$TMP" "
SELECT
  COALESCE(b.title, '(untitled)'),
  p.url
FROM moz_bookmarks b
JOIN moz_places p ON b.fk = p.id
WHERE b.type = 1
  AND p.url IS NOT NULL
ORDER BY b.title;
"

rm -f "$TMP"
